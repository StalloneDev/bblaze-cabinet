datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Service {
  id          String @id // e.g. "ingenierie-juridique"
  title       String
  description String
  content     String @db.Text
  icon        String // e.g. "Briefcase", "Users", etc.
}

model ContactInfo {
  id             String @id @default("singleton")
  email          String
  phone          String
  address        String
  whatsappNumber String
  whatsappMsg    String
}

model Post {
  id        Int      @id @default(autoincrement())
  title     String
  content   String   @db.Text
  imageUrl  String?  @db.Text // Base64 string for images
  category  String   @default("Actu")
  createdAt DateTime @default(now())
}

model Message {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  subject   String
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
